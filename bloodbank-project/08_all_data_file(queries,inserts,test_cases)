CREATE OR REPLACE PROCEDURE issue_unit(
    p_request_id IN NUMBER,
    p_unit_id IN NUMBER,
    p_staff_id IN NUMBER
) IS
    v_unit_status VARCHAR2(15);
    v_recipient_blood_group VARCHAR2(3);
    v_donor_blood_group VARCHAR2(3);
    v_request_status VARCHAR2(15);
    v_compatible_list VARCHAR2(500);
BEGIN

    BEGIN
        SELECT status INTO v_unit_status
        FROM blood_unit
        WHERE unit_id = p_unit_id
        FOR UPDATE NOWAIT;
    EXCEPTION
        WHEN OTHERS THEN
            RAISE_APPLICATION_ERROR(-20010, 'Unit is locked or unavailable for issuance (possibly being issued by another session)');
    END;
    
    
    IF v_unit_status != 'AVAILABLE' THEN
        RAISE_APPLICATION_ERROR(-20011, 'Unit status is ' || v_unit_status || '; only AVAILABLE units can be issued');
    END IF;
    
   
    SELECT r.recipient_id
    INTO v_recipient_blood_group
    FROM request r
    WHERE r.request_id = p_request_id;
   
    SELECT rec.blood_group
    INTO v_recipient_blood_group
    FROM recipient rec
    WHERE rec.recipient_id = (
        SELECT recipient_id FROM request WHERE request_id = p_request_id
    );
    
   
    SELECT d.blood_group
    INTO v_donor_blood_group
    FROM donor d
    WHERE d.donor_id = (
        SELECT don.donor_id
        FROM donation don
        WHERE don.donation_id = (
            SELECT bu.donation_id
            FROM blood_unit bu
            WHERE bu.unit_id = p_unit_id
        )
    );

    v_compatible_list := get_compatible_groups(v_recipient_blood_group);
    
    IF INSTR(v_compatible_list, v_donor_blood_group) = 0 THEN
        RAISE_APPLICATION_ERROR(-20012, 
            'Blood group mismatch: recipient ' || v_recipient_blood_group || 
            ' cannot receive from donor ' || v_donor_blood_group);
    END IF;
    
   
    INSERT INTO issuance (issuance_id, request_id, unit_id, issued_on, issued_by)
    VALUES (issuance_seq.NEXTVAL, p_request_id, p_unit_id, SYSDATE, p_staff_id);
    
  
    UPDATE blood_unit
    SET status = 'ISSUED'
    WHERE unit_id = p_unit_id;
 
    INSERT INTO audit_log (audit_id, table_name, op_type, record_pk, old_value, new_value, changed_by)
    VALUES (audit_seq.NEXTVAL, 'blood_unit', 'UPDATE', p_unit_id, 'AVAILABLE', 'ISSUED', USER);
    
  
    COMMIT;
    
    DBMS_OUTPUT.PUT_LINE('Unit ' || p_unit_id || ' issued successfully to request ' || p_request_id);

EXCEPTION
    WHEN OTHERS THEN
        ROLLBACK;
        DBMS_OUTPUT.PUT_LINE('ISSUANCE FAILED: ' || SQLCODE || ' - ' || SQLERRM);
        RAISE;
END issue_unit;
/


CREATE OR REPLACE TRIGGER trg_donation_eligibility
BEFORE INSERT ON donation
FOR EACH ROW
DECLARE
    v_last_donation_date DATE;
BEGIN
    -- Fetch last donation date
    SELECT last_donation_date
    INTO v_last_donation_date
    FROM donor
    WHERE donor_id = :NEW.donor_id;

    -- Check 90-day rule using the NEW donation date
    IF v_last_donation_date IS NOT NULL
       AND TRUNC(:NEW.donation_date) - TRUNC(v_last_donation_date) < 90 THEN
       
        RAISE_APPLICATION_ERROR(
            -20020,
            'Donor ' || :NEW.donor_id || 
            ' is within 90-day deferral period'
        );
    END IF;

EXCEPTION
    WHEN NO_DATA_FOUND THEN
        RAISE_APPLICATION_ERROR(
            -20021,
            'Donor ' || :NEW.donor_id || ' does not exist'
        );
END trg_donation_eligibility;
/


CREATE OR REPLACE TRIGGER trg_unit_release
AFTER UPDATE ON screening
FOR EACH ROW
BEGIN
    IF :NEW.hiv = 'NEGATIVE' AND :NEW.hbv = 'NEGATIVE' 
       AND :NEW.hcv = 'NEGATIVE' AND :NEW.syphilis = 'NEGATIVE' 
       AND :NEW.malaria = 'NEGATIVE' THEN
        UPDATE blood_unit SET status = 'AVAILABLE'
        WHERE unit_id = :NEW.unit_id AND status = 'QUARANTINE';
    END IF;
END;
/


CREATE OR REPLACE TRIGGER trg_audit_donor
AFTER INSERT OR UPDATE ON donor
FOR EACH ROW
DECLARE
    v_audit_id NUMBER;
    v_op_type VARCHAR2(10);
BEGIN
    SELECT audit_seq.NEXTVAL INTO v_audit_id FROM dual;
    
    IF INSERTING THEN v_op_type := 'INSERT';
    ELSIF UPDATING THEN v_op_type := 'UPDATE';
    END IF;

    INSERT INTO audit_log (audit_id, table_name, op_type, record_pk, old_value, new_value, changed_by)
    VALUES (v_audit_id, 'donor', v_op_type, TO_CHAR(:NEW.donor_id),
            CASE WHEN UPDATING THEN :OLD.full_name ELSE NULL END,
            :NEW.full_name, USER);
EXCEPTION
    WHEN OTHERS THEN NULL;
END;
/



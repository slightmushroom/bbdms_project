CREATE OR REPLACE FUNCTION calc_expiry_date(
    p_component_id IN NUMBER,
    p_collection_date IN DATE
) RETURN DATE IS
    v_shelf_life NUMBER;
    v_expiry_date DATE;
BEGIN
    -- Look up the shelf life for this component
    SELECT shelf_life_days INTO v_shelf_life
    FROM component
    WHERE component_id = p_component_id;
    
    -- Calculate expiry
    v_expiry_date := p_collection_date + v_shelf_life;
    
    RETURN v_expiry_date;
    
EXCEPTION
    WHEN NO_DATA_FOUND THEN
        DBMS_OUTPUT.PUT_LINE('ERROR: Component ' || p_component_id || ' not found');
        RETURN NULL;
    WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('ERROR: ' || SQLCODE || ' - ' || SQLERRM);
        RETURN NULL;
END calc_expiry_date;
/





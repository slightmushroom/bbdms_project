    MAX(i.issued_on) AS last_issuance_date
FROM staff s
LEFT JOIN donation d ON s.staff_id = d.staff_id
LEFT JOIN issuance i ON s.staff_id = i.issued_by
WHERE s.is_active = 'Y'
GROUP BY s.staff_id, s.full_name, s.role
ORDER BY s.staff_id;

SELECT 
    h.hospital_id,
    h.name AS hospital,
    COUNT(r.request_id) AS total_requests,
    COUNT(CASE WHEN r.status = 'OPEN' THEN 1 END) AS open_requests,
    COUNT(CASE WHEN r.status = 'FULFILLED' THEN 1 END) AS fulfilled_requests,
    SUM(r.units_needed) AS units_requested,
    ROUND(
        100 * COUNT(CASE WHEN r.status = 'FULFILLED' THEN 1 END) 
        / NULLIF(COUNT(r.request_id), 0),
        1
    ) AS fulfillment_rate
FROM hospital h
LEFT JOIN recipient rec ON h.hospital_id = rec.hospital_id
LEFT JOIN request r ON rec.recipient_id = r.recipient_id
GROUP BY h.hospital_id, h.name
ORDER BY total_requests DESC;



SELECT 
    d.donor_id,
    d.full_name,
    d.blood_group,
    TO_CHAR(d.last_donation_date, 'YYYY-MM-DD') AS last_donated,
    (SELECT MAX(bu.unit_id) 
     FROM blood_unit bu 
     WHERE bu.donation_id = (SELECT donation_id FROM donation WHERE donor_id = d.donor_id ORDER BY donation_date DESC FETCH FIRST 1 ROW ONLY)
    ) AS latest_unit_id,
    (SELECT bu.status
     FROM blood_unit bu
     WHERE bu.donation_id = (SELECT donation_id FROM donation WHERE donor_id = d.donor_id ORDER BY donation_date DESC FETCH FIRST 1 ROW ONLY)
    ) AS latest_unit_status
FROM donor d
WHERE d.is_active = 'Y'
ORDER BY d.last_donation_date DESC NULLS LAST;



SELECT 
    c.component_id,
    c.name,
    c.shelf_life_days,
    COUNT(bu.unit_id) AS total_units,
    COUNT(CASE WHEN bu.status = 'AVAILABLE' THEN 1 END) AS available_units,
    ROUND(AVG(bu.expiry_date - bu.collection_date), 1) AS avg_stored_days,
    ROUND(100 * AVG(bu.expiry_date - bu.collection_date) / c.shelf_life_days, 1) AS avg_percent_shelf_used
FROM component c
LEFT JOIN blood_unit bu ON c.component_id = bu.component_id
GROUP BY c.component_id, c.name, c.shelf_life_days
ORDER BY c.component_id;



SELECT 

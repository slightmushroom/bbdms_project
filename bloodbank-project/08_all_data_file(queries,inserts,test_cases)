CREATE OR REPLACE FUNCTION get_compatible_groups(
    p_recipient_group IN VARCHAR2
) RETURN VARCHAR2 IS
    v_compatible_list VARCHAR2(500);
BEGIN
    SELECT LISTAGG(donor_group, ', ') WITHIN GROUP (ORDER BY donor_group)
    INTO v_compatible_list
    FROM blood_compatibility
    WHERE recipient_group = p_recipient_group;
    
    RETURN v_compatible_list;
    
EXCEPTION
    WHEN NO_DATA_FOUND THEN
        DBMS_OUTPUT.PUT_LINE('ERROR: No compatible groups for ' || p_recipient_group);
        RETURN NULL;
    WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('ERROR: ' || SQLCODE || ' - ' || SQLERRM);
        RETURN NULL;
END get_compatible_groups;

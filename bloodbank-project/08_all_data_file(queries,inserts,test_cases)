SELECT r.request_id,
       rec.full_name AS recipient,
       rec.blood_group,
       h.name        AS hospital,
       c.name        AS component_needed,
       r.units_needed,
       r.urgency,
       COUNT(bu.unit_id) AS compatible_available
FROM request r
JOIN recipient rec ON r.recipient_id = rec.recipient_id
JOIN hospital h    ON rec.hospital_id = h.hospital_id
JOIN component c   ON r.component_id  = c.component_id
LEFT JOIN blood_unit bu ON bu.component_id = r.component_id
    AND bu.status = 'AVAILABLE'
    AND bu.donation_id IN (
        SELECT don.donation_id FROM donation don
        JOIN donor d ON don.donor_id = d.donor_id
        WHERE d.blood_group IN (
            SELECT donor_group FROM blood_compatibility
            WHERE recipient_group = rec.blood_group))
WHERE r.status = 'OPEN'
GROUP BY r.request_id, rec.full_name, rec.blood_group,
         h.name, c.name, r.units_needed, r.urgency
ORDER BY r.urgency DESC, MAX(r.request_date) DESC;



SELECT c.component_id,
       c.name,
       c.shelf_life_days,
       COUNT(bu.unit_id)    AS total_units,
       COUNT(CASE WHEN bu.status = 'AVAILABLE' THEN 1 END)
                            AS available_units,
       ROUND(AVG(bu.expiry_date - bu.collection_date), 1)
                            AS avg_stored_days,
       ROUND(100 * AVG(bu.expiry_date - bu.collection_date)
             / c.shelf_life_days, 1) AS avg_pct_shelf_used
FROM component c
LEFT JOIN blood_unit bu ON c.component_id = bu.component_id
GROUP BY c.component_id, c.name, c.shelf_life_days
ORDER BY c.component_id;






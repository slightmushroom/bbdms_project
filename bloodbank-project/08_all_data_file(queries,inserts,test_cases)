SELECT 
    d.donor_id,
    d.full_name,
    d.blood_group,
    COUNT(don.donation_id) AS total_donations,
    TO_CHAR(MAX(don.donation_date), 'YYYY-MM-DD') AS last_donation,
    CASE 
        WHEN donor_eligible(d.donor_id) = TRUE THEN 'ELIGIBLE'
        WHEN donor_eligible(d.donor_id) = FALSE THEN 'NOT YET ELIGIBLE'
        ELSE 'UNKNOWN'
    END AS status
FROM donor d
LEFT JOIN donation don ON d.donor_id = don.donor_id
GROUP BY d.donor_id, d.full_name, d.blood_group
ORDER BY d.donor_id;


SELECT 
    d.blood_group,
    c.name AS component,
    COUNT(bu.unit_id) AS available_units,
    MIN(bu.expiry_date) AS expires_soonest
FROM blood_unit bu
JOIN component c ON bu.component_id = c.component_id
JOIN donation don ON bu.donation_id = don.donation_id
JOIN donor d ON don.donor_id = d.donor_id
WHERE bu.status = 'AVAILABLE'
GROUP BY d.blood_group, c.name
ORDER BY d.blood_group, c.name;


SELECT 
    bu.unit_id,
    d.full_name AS donor,
    d.blood_group,
    c.name AS component,
    bu.status,
    TO_CHAR(bu.expiry_date, 'YYYY-MM-DD') AS expires,
    TRUNC(bu.expiry_date - SYSDATE) AS days_remaining
FROM blood_unit bu
JOIN donation don ON bu.donation_id = don.donation_id
JOIN donor d ON don.donor_id = d.donor_id
JOIN component c ON bu.component_id = c.component_id
WHERE bu.expiry_date BETWEEN SYSDATE AND SYSDATE + 7
  AND bu.status IN ('AVAILABLE', 'RESERVED')
ORDER BY bu.expiry_date;


SELECT 
    r.request_id,
    rec.full_name AS recipient,
    rec.blood_group,
    h.name AS hospital,
    c.name AS component_needed,
    r.units_needed,
    r.urgency,
    COUNT(bu.unit_id) AS compatible_available
FROM request r
JOIN recipient rec ON r.recipient_id = rec.recipient_id
JOIN hospital h ON rec.hospital_id = h.hospital_id
JOIN component c ON r.component_id = c.component_id
LEFT JOIN blood_unit bu ON bu.component_id = r.component_id
    AND bu.status = 'AVAILABLE'
    AND bu.donation_id IN (
        SELECT don.donation_id 
        FROM donation don
        JOIN donor d ON don.donor_id = d.donor_id
        WHERE d.blood_group IN (
            SELECT donor_group 
            FROM blood_compatibility 
            WHERE recipient_group = rec.blood_group
        )
    )
WHERE r.status = 'OPEN'
GROUP BY 
    r.request_id, rec.full_name, rec.blood_group, h.name, c.name, r.units_needed, r.urgency
ORDER BY r.urgency DESC, MAX(r.request_date) DESC;



SELECT 

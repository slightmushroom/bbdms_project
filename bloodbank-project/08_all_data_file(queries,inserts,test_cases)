        WHEN contact LIKE '+91-988%' THEN 'South'
        ELSE 'Other'
    END AS region,
    COUNT(*) AS donor_count,
    ROUND(AVG(MONTHS_BETWEEN(SYSDATE, dob) / 12), 1) AS avg_age
FROM donor
GROUP BY CASE 
    WHEN contact LIKE '+91-987%' THEN 'North'
    WHEN contact LIKE '+91-988%' THEN 'South'
